# For noisy OCR PDFs and unstable formatting
STRUCTURE_PASS_ENABLED=true
STRUCTURE_PASS_USE_LLM=true
STRUCTURE_MIN_HEADING_SCORE=0.45
STRUCTURE_MAX_HEADINGS_FOR_LLM=120
STRUCTURE_MAX_SECTION_SIZE_CHARS=120000

STRUCTURAL_CHUNKER_ENABLED=true
STRUCTURAL_CHUNKER_TARGET_SIZE=10000
STRUCTURAL_CHUNKER_MIN_SIZE=2000
STRUCTURAL_CHUNKER_SPLIT_WINDOW=300
STRUCTURAL_CHUNKER_EXCLUDED_TYPES=index,bibliography
