# For clean PDFs with clear headings and good layout
STRUCTURE_PASS_ENABLED=true
STRUCTURE_PASS_USE_LLM=true
STRUCTURE_MIN_HEADING_SCORE=0.65
STRUCTURE_MAX_HEADINGS_FOR_LLM=250
STRUCTURE_MAX_SECTION_SIZE_CHARS=220000

STRUCTURAL_CHUNKER_ENABLED=true
STRUCTURAL_CHUNKER_TARGET_SIZE=16000
STRUCTURAL_CHUNKER_MIN_SIZE=4000
STRUCTURAL_CHUNKER_SPLIT_WINDOW=500
STRUCTURAL_CHUNKER_EXCLUDED_TYPES=index,bibliography
